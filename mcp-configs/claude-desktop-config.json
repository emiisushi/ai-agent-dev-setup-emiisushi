{
  "mcpServers": {
    "rolldice": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://rolldice-mcpserver.vercel.app/api/mcp"
      ]
    },
    "calendar-booking": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://booking-cal.ausbizconsulting.com.au/api/mcp"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_TOKEN_HERE"
      }
    }
  }
}
